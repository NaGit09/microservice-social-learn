# JWT secret key 
JWT_SECRET=super_secret_jwt_access_key_12345
JWT_REFRESH_SECRET=super_secret_jwt_refresh_key_12345

# Service port
PORT=8081

# MongoDB connection string
MONGODB_URL=mongodb://mongodb:27017/auth_service

# Kafka config
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=auth-service
KAFKA_GROUP_ID=auth-service-consumer

# Redis config
REDIS_HOST=my-redis
REDIS_PORT=6379

